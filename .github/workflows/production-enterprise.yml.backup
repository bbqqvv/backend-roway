name: Global Enterprise Infrastructure (Staff Level - Backup)

# Backup file: Chờ khi có VPS thì đổi tên thành ci-cd.yml và nạp Secret

on:
  workflow_dispatch: # Chỉ chạy khi ấn nút tay để tránh tốn tài nguyên lúc này

concurrency:
  group: deploy-${{ github.ref }}
  cancel-in-progress: true

jobs:
  db-migration:
    name: Database Migration Check
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-java@v4
        with: { java-version: '21', distribution: 'temurin', cache: maven }
      - name: Run Liquibase
        run: ./mvnw liquibase:update -Dliquibase.url=${{ secrets.DB_URL }} -Dliquibase.username=${{ secrets.DB_USERNAME }} -Dliquibase.password=${{ secrets.DB_PASSWORD }}

  quality-gate:
    name: Quality Gate
    needs: db-migration
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:15-alpine
        env: { POSTGRES_DB: roway_db, POSTGRES_USER: postgres, POSTGRES_PASSWORD: password }
        ports: [5432:5432]
      redis:
        image: redis:7-alpine
        ports: [6379:6379]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-java@v4
        with: { java-version: '21', distribution: 'temurin', cache: maven }
      - run: ./mvnw clean verify jacoco:check -Pproduction
      - uses: actions/upload-artifact@v4
        with: { name: app-jar, path: target/*.jar }

  container-security:
    name: Dockerize & Security Scan
    needs: quality-gate
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/download-artifact@v4
        with: { name: app-jar, path: target/ }
      - uses: docker/login-action@v3
        with: { username: ${{ secrets.DOCKERHUB_USERNAME }}, password: ${{ secrets.DOCKERHUB_TOKEN }} }
      - uses: docker/build-push-action@v5
        with:
          context: .
          load: true
          tags: ${{ secrets.DOCKERHUB_USERNAME }}/roway-backend:${{ github.sha }}
      - uses: aquasecurity/trivy-action@v0.20.0
        with: { image-ref: '${{ secrets.DOCKERHUB_USERNAME }}/roway-backend:${{ github.sha }}', exit-code: 1, severity: 'CRITICAL,HIGH' }
      - name: Atomic Push
        run: |
          docker push ${{ secrets.DOCKERHUB_USERNAME }}/roway-backend:${{ github.sha }}
          docker tag ${{ secrets.DOCKERHUB_USERNAME }}/roway-backend:${{ github.sha }} ${{ secrets.DOCKERHUB_USERNAME }}/roway-backend:latest
          docker push ${{ secrets.DOCKERHUB_USERNAME }}/roway-backend:latest

  deployment:
    name: Advanced Deployment
    needs: container-security
    runs-on: ubuntu-latest
    environment: production
    steps:
      - uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.PROD_HOST }}
          username: ${{ secrets.SERVER_USER }}
          key: ${{ secrets.SSH_PRIVATE_KEY }}
          script: |
            # ... (Script Blue-Green Lite + Health Check đã lưu ở bản trước) ...
            echo "Deploying ${{ github.sha }}..."
            # [Full Script in backup]
